# Copy this file to .env and fill in real values.
# The .env file is gitignored. Never commit secrets.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_NAME=vormox_db
DB_USER=vormox_db
DB_PASS=change-me
DB_CHARSET=utf8mb4

# ---------------------------------------------------------------------------
# Public site URL (used in email links)
# ---------------------------------------------------------------------------
SITE_URL=https://app.vormox.com

# ---------------------------------------------------------------------------
# Mail (ZeptoMail)
# ---------------------------------------------------------------------------
# Full header value, e.g. "Zoho-enczapikey PHtE6r0LRbu9..."
ZEPTOMAIL_AUTH=
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME=Vormox

# ---------------------------------------------------------------------------
# Internal API token used by api/panel.php
# ---------------------------------------------------------------------------
API_PANEL_TOKEN=change-me

# ---------------------------------------------------------------------------
# Cron — backend lifecycle trigger
# ---------------------------------------------------------------------------
# Must match the X-Cron-Secret header expected by the backend
CRON_SECRET=change-me

# Optional cron tunables (defaults shown)
# BACKEND_LIFECYCLE_PORT=8080
# BACKEND_LIFECYCLE_PATH=/api/internal/cron/trigger-lifecycle
# LIFECYCLE_HTTP_TIMEOUT=8
# LIFECYCLE_CONNECT_TIMEOUT=3
# SUSPEND_AFTER_DAYS=7
# REMINDER_DAYS_BEFORE_EXPIRY=5
